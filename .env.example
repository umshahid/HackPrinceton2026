# Gemini API Key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic API Key (get from https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude Code path (usually just "claude" if installed globally)
CLAUDE_CODE_PATH=claude

# AI Engine: gemini_live or claude
DEFAULT_AI_ENGINE=gemini_live

# Display settings (used for HUD rendering + virtual camera)
VIRTUAL_CAM_WIDTH=1280
VIRTUAL_CAM_HEIGHT=720
VIRTUAL_CAM_FPS=20

# WhatsApp window title (for OBS mode screen capture)
WHATSAPP_WINDOW_TITLE=WhatsApp
